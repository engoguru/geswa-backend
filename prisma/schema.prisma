datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}


// user-schema
enum UserRole {
  ADMIN
  EMPLOYEE
  HOSPITAL
  MEMBER
}
model User {
  id        Int      @id @default(autoincrement())

  name      String
  email     String   @unique
  contact   String   @unique
  password  String

  role      UserRole @default(MEMBER)

  employee  Employee?

  isVerified Boolean  @default(false)
  lastLogin  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otps      Otptable[]

  membershipPurchases MembershipPurchase[]

  hospitalUser HospitalUser?
}

model Otptable {
  id          Int       @id @default(autoincrement())

  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  code        String
  type        OTPType

  expiresAt   DateTime
  verified    Boolean   @default(false)

  createdAt   DateTime  @default(now())
}

enum OTPType {
  EMAIL_VERIFICATION
  LOGIN
  FORGOT_PASSWORD
  PHONE_VERIFICATION
}


model Employee { 
  id                Int      @id @default(autoincrement())

  userId            Int      @unique

  dob               DateTime?
  highestEducation  String?

  address           String?
  state             String?
  district          String?
  pincode           String?

  bankName          String?
  accountNumber     String?
  ifscCode          String?
  branchName        String?

  profileUrl        String?
  profilePublicId   String?

  aadharUrl         String?
  aadharPublicId    String?

  panUrl            String?
  panPublicId       String?

  user              User @relation(fields: [userId], references: [id])

 employeeAssignments EmployeeAssignment[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())

  name      String   @unique
  code      String?  @unique

  roles     Role[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeAssignments EmployeeAssignment[]
}

model Role {
  id            Int      @id @default(autoincrement())

  name          String

  departmentId  Int

  department    Department @relation(fields: [departmentId], references: [id])

 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([departmentId, name])

  employeeAssignments EmployeeAssignment[]
}

model State {
  id   Int @id @default(autoincrement())
  name String @unique

  districts District[]
  employeeAssignments EmployeeAssignment[]
}

model District {
  id      Int @id @default(autoincrement())

  name    String

  stateId Int

  state State @relation(fields: [stateId], references: [id])

  talukas Taluka[]


  employeeAssignments EmployeeAssignment[]
}

model Taluka {
  id         Int @id @default(autoincrement())

  name       String

  districtId Int

  district District @relation(fields: [districtId], references: [id])

  villages Village[]

  employeeAssignments EmployeeAssignment[]
}

model Village {
  id       Int @id @default(autoincrement())

  name     String

  talukaId Int

  taluka Taluka @relation(fields: [talukaId], references: [id])

  employeeAssignments EmployeeAssignment[]
}

model EmployeeAssignment {
  id Int @id @default(autoincrement())

  employeeId   Int
  departmentId Int
  roleId       Int

  stateId      Int?
  districtId   Int?
  talukaId     Int?
  villageId    Int?

  isActive   Boolean @default(true)

  employee   Employee   @relation(fields: [employeeId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])

  state    State?    @relation(fields: [stateId], references: [id])
  district District? @relation(fields: [districtId], references: [id])
  taluka   Taluka?   @relation(fields: [talukaId], references: [id])
  village  Village?  @relation(fields: [villageId], references: [id])

  membershipPurchases MembershipPurchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}









// contact schema 
model Contact {
  id        Int      @id @default(autoincrement())

  name      String
  contact   String
  email     String

  subject   String?
  message   String?
  status    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Hospital model
model Hospital {
  id            Int       @id @default(autoincrement())

  name          String
  tagline       String?
  rating        Float?
  reviews       Int?

  address       String
  city          String
  state         String
  zip           String
  about         String?

  services      String[]  // Service names

  availability  String?
  contact       String
  email         String?

  // NEW IMAGE FIELDS
  imageUrl        String?
  imagePublicKey  String?

  doctors       Doctor[]
  hospitalUsers HospitalUser?
  serviceHistory MembershipServiceHistory[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Doctor {
  id            Int       @id @default(autoincrement())

  name          String
  specialty     String
  experience    Int?

  // NEW IMAGE FIELDS
  imageUrl        String?
  imagePublicKey  String?

  hospitalId    Int      
  hospital      Hospital  @relation(fields: [hospitalId], references: [id])

  createdAt     DateTime  @default(now())
}

model HospitalUser {
  id Int @id @default(autoincrement())

  userId Int @unique
  user User @relation(fields: [userId], references: [id])

  hospitalId Int @unique
  hospital Hospital @relation(fields: [hospitalId], references: [id])

  createdAt DateTime @default(now())
}



//  blog
model Blog {
  id          Int    @id @default(autoincrement())



  title       String
  
  excerpt     String?

  content     String   // Jodit HTML content

  imageUrl       String?
  imagePublicKey String?

 

  metaTitle       String?
  metaDescription String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

}





//  career page
model Job {
  id               Int     @id @default(autoincrement())

  title            String
  description      String   @db.Text

  responsibilities String[]
  requirements     String[]
  benefits         String[]

  location         String
  salaryRange      String?

  employmentType   String
  experience       String

  isActive         Boolean  @default(true)

  applications     Application[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Application {
  id               Int    @id @default(autoincrement())

  fullName         String
  email            String
  phone            String

  experience       String?
  coverLetter      String? @db.Text

  resume_publicId  String
  resume_Url       String

  status           ApplicationStatus @default(PENDING)

  jobId            Int 
  job              Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}


//   membership handle -----------------------------------------------------

enum DurationUnit {
  MONTH
  YEAR
  LIFETIME
}

model Membership {
  id            Int      @id @default(autoincrement())

  name          String
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)

  durationValue Int?
  durationUnit  DurationUnit

  benefits      String[]

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases     MembershipPurchase[]
}
model MembershipPurchase {
  id Int @id @default(autoincrement())

  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeAssignmentId Int
  employeeAssignment EmployeeAssignment @relation(fields: [employeeAssignmentId], references: [id], onDelete: Cascade)

  membershipId Int
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  serviceHistory MembershipServiceHistory[]

  memberId String @unique

  amountPaid Decimal @db.Decimal(10, 2)

  paymentStatus PaymentStatus @default(PENDING)
  status MembershipStatus @default(ACTIVE)

  startDate DateTime
  endDate DateTime?

  transactionId String?
  paymentMethod String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}


model MembershipServiceHistory {
  id Int @id @default(autoincrement())

 membershipPurchaseId Int
membershipPurchase MembershipPurchase @relation(fields: [membershipPurchaseId], references: [id], onDelete: Cascade)

hospitalId Int
hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  serviceName String
  serviceDetails String? @db.Text

  actualBillAmount Decimal @db.Decimal(10,2)
  offerAmount Decimal @default(0) @db.Decimal(10,2)
  finalAmount Decimal @db.Decimal(10,2)

  bill_publicId String?
  bill_Url String?

  usedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}